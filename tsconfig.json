{
  "compilerOptions": {
    // Target / module — Vite handles the actual transpilation; tsc here
    // is type-check-only via `noEmit`. Keep target/module modern so we
    // don't lie to the type checker about ES syntax availability.
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",
    "useDefineForClassFields": true,

    // The migration is complete — src/ is 100% TypeScript. allowJs is off,
    // so a stray .js under src/ silently won't be type-checked; the include
    // glob is also restricted to .ts/.tsx to keep that explicit.
    "allowJs": false,

    // Strict mode on the TS surface that exists today. Cheap to keep
    // on because the migration starts small.
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,

    // Build hygiene
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    // No baseUrl/paths yet — keep imports relative to avoid invisible
    // aliasing that Vite + tsc + ESLint all have to agree on.
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
