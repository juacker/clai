{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clai",
  "version": "0.1.0",
  "identifier": "com.juacker.clai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CLAI",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/juacker/clai/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI1MzAxN0M5RUI0Q0MwMzkKUldRNXdFenJ5UmN3dGMyQWx0ZmxVUURXZ2QxOCsyT2pzR1RNb3JCMXBCR1BHVk52Q1ZtZU9yVHcK"
    }
  }
}
