# Maintainer: juacker <your-email@example.com>
pkgname=clai
pkgver=0.1.0
pkgrel=1
pkgdesc="Command Line AI Interface for Netdata"
arch=('x86_64')
url="https://github.com/juacker/clai"
license=('MIT')
depends=('webkit2gtk-4.1' 'gtk3' 'libappindicator-gtk3')
makedepends=('rust' 'cargo' 'nodejs' 'npm' 'base-devel')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/juacker/clai/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
    cd "${pkgname}-${pkgver}"

    # Build frontend
    npm ci
    npm run build

    # Build Tauri backend
    cd src-tauri
    cargo build --release
}

package() {
    cd "${pkgname}-${pkgver}"

    # Install binary
    install -Dm755 "src-tauri/target/release/clai" "${pkgdir}/usr/bin/clai"

    # Install desktop file
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/clai.desktop" << EOF
[Desktop Entry]
Name=CLAI
Comment=Command Line AI Interface for Netdata
Exec=clai
Icon=clai
Terminal=false
Type=Application
Categories=Development;Utility;
Keywords=AI;Netdata;CLI;Chat;
EOF

    # Install icons
    install -Dm644 "src-tauri/icons/32x32.png" "${pkgdir}/usr/share/icons/hicolor/32x32/apps/clai.png"
    install -Dm644 "src-tauri/icons/128x128.png" "${pkgdir}/usr/share/icons/hicolor/128x128/apps/clai.png"
    install -Dm644 "src-tauri/icons/icon.png" "${pkgdir}/usr/share/icons/hicolor/512x512/apps/clai.png"

    # Install license
    install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
